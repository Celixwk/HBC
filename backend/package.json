{
  "name": "hotel-boutique-app",
  "version": "1.0.0",
  "description": "Sistema Hotel Boutique con Base de Datos Embebida",
  "main": "electron/main.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "dist": "npx prisma generate --schema=prisma/schema.prisma && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "build": {
    "appId": "com.hotelboutique.app",
    "productName": "Hotel Boutique",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "src/**/*",
      "electron/**/*",
      "prisma/**/*",
      "frontend-build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "postgres-portable",
        "to": "postgres-portable",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.1.14"
  }
}
